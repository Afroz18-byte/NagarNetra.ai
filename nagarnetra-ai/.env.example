# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_PROJECT_ID: Required for Firebase App initialization.
FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_API_KEY: Required for Firebase Web API authentication.
FIREBASE_API_KEY=your-firebase-api-key
# FIREBASE_APP_ID: Required for Firebase Client App configuration.
FIREBASE_APP_ID=1:123456789012:android:abcdef1234567890

# GOOGLE_MAPS_KEY: Required for Google Maps Integration showing heatmaps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSyDrctki_MLm7xlLQ7qLuQwKv_265oGW0aM........

# EMAILJS CREDENTIALS: Required for the Automated Accountability Engine to dispatch reports
EMAILJS_SERVICE_ID=your-emailjs-service-id
EMAILJS_TEMPLATE_ID=your-emailjs-template-id
EMAILJS_PUBLIC_KEY=your-emailjs-public-key

# CLAUDE_API_KEY: Required for Claude 3.5 Sonnet VisionBot image analysis.
CLAUDE_API_KEY=your-claude-api-key



